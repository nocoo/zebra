{
  "name": "pew-monorepo",
  "version": "0.3.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "bun run --cwd packages/web dev",
    "build": "bun run --filter '*' build",
    "lint": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p packages/cli/tsconfig.json && tsc --noEmit -p packages/web/tsconfig.json && tsc --noEmit -p packages/worker/tsconfig.json",
    "test:e2e": "bun run scripts/run-e2e.ts",
    "test:e2e:cli": "vitest run --config vitest.e2e-cli.config.ts",
    "test:e2e:ui": "bun run scripts/run-e2e-ui.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
